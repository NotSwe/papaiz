{
    "name": "iqc-canvas",
    "version": "1.0.37",
    "description": "Screenshot iPhone WhatsApp Chat Generator by Hann Universe",
    "main": "./dist/cjs/index.cjs",
    "module": "./dist/esm/index.js",
    "exports": {
        ".": {
            "require": "./dist/cjs/index.cjs",
            "import": "./dist/esm/index.js"
        }
    },
    "type": "commonjs",
    "files": [
        "dist",
        "assets",
        "lib",
        "README.md"
    ],
    "scripts": {
        "start": "node index.js",
        "build": "rollup -c rollup.config.mjs",
        "prepublishOnly": "npm run build",
        "test:cjs": "node -e \"const {generateIQC} = require('./dist/cjs/index.cjs'); console.log('✅ CJS OK')\"",
        "test:esm": "node --input-type=module -e \"import('./dist/esm/index.js').then(m => console.log('✅ ESM OK'))\""
    },
    "keywords": [
        "canvas",
        "iqc",
        "whatsapp",
        "iphone",
        "ios",
        "quote",
        "image-generator"
    ],
    "author": "hannuniverse",
    "license": "MIT",
    "dependencies": {
        "@napi-rs/canvas": "^0.1.84",
        "emoji-db": "^15.1.2"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^25.0.0",
        "@rollup/plugin-json": "^6.0.0",
        "@rollup/plugin-node-resolve": "^15.0.0",
        "rollup": "^4.62.2"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Hanzz98/iqc-canvas.git"
    },
    "bugs": {
        "url": "https://github.com/Hanzz98/iqc-canvas/issues"
    },
    "homepage": "https://github.com/Hanzz98/iqc-canvas#readme"
}
